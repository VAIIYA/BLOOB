# ─── AgarSol Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in real values for local development.
# For production, set these in the Vercel dashboard.

# ── Vercel Postgres ─────────────────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Your Postgres DB → .env.local tab
POSTGRES_URL=postgres://...

# ── PartyKit ────────────────────────────────────────────────────────────────
# After running `npx partykit deploy`, your host will be:
# <project-name>.<your-username>.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=agarsol.yourusername.partykit.dev

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string

# ── Solana Network ───────────────────────────────────────────────────────────
# Use "devnet" for testing, "mainnet-beta" for production
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ── Internal API Secret ──────────────────────────────────────────────────────
# Used to authenticate PartyKit → Next.js API calls (game/end route)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=replace_with_another_random_secret
